# =============================================================================
# CasaRespuestos API — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Port the NestJS server listens on
PORT=3000

# Node environment: development | production | test
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database — individual vars (used by TypeORM config object)
# -----------------------------------------------------------------------------

DB_HOST=localhost
DB_PORT=5432
DB_NAME=casarespuestos_dev
DB_USER=casarespuestos
DB_PASSWORD=your-database-password-here

# -----------------------------------------------------------------------------
# Database — connection string (alternative; can be used instead of individual vars)
# TypeORM accepts either style. Individual vars are preferred for Railway deploys
# where DATABASE_URL is injected automatically.
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# -----------------------------------------------------------------------------
# JWT — Access Token
# Short-lived token sent with every API request (Authorization: Bearer <token>)
# -----------------------------------------------------------------------------

JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m

# -----------------------------------------------------------------------------
# JWT — Refresh Token
# Long-lived token used to obtain a new access token when it expires.
# Must be different from the access secret.
# -----------------------------------------------------------------------------

JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed frontend origins.
# Example: https://casarespuestos.vercel.app,https://staging.casarespuestos.vercel.app
# -----------------------------------------------------------------------------

CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Bcrypt
# Cost factor for password hashing. 10–12 is a sensible range.
# Higher = slower hash (more secure but more CPU).
# -----------------------------------------------------------------------------

BCRYPT_ROUNDS=10

# -----------------------------------------------------------------------------
# Seed — first admin user (npm run seed:admin)
# Only used by the seed script; change the password after first login.
# -----------------------------------------------------------------------------

SEED_ADMIN_EMAIL=admin@casarespuestos.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=User
